# ============================================================
#  InstaCafe Backend — Environment Variables
#  (loaded by config/env.js with zod validation at boot)
# ============================================================

# ---- Runtime ----
NODE_ENV=development        # development | test | production
PORT=4469
BODY_LIMIT=100kb            # Express JSON body limit

# ---- Database (either name works; MONGO_URL wins if both set) ----
MONGO_USER=naruto
MONGO_PASSWORD=your_atlas_password
MONGO_CLUSTER=cluster0.hb9bq3v.mongodb.net
MONGO_DB_NAME=instacafe
MONGO_URL=
MONGODB_URI=

# ---- InstaCafe JWT (required) ----
# min 16 chars in dev/test, 32 chars in production
JWT_SECRET=change_me_to_a_long_random_secret_key_32chars
JWT_EXPIRE=7d
REFRESH_TOKEN_EXPIRE=30d

# ---- Legacy IMS JWT ----
# MUST differ from JWT_SECRET in production. Token expiry default 12h.
LEGACY_JWT_SECRET=change_me_legacy_secret_must_differ_from_jwt_secret
LEGACY_JWT_EXPIRE=12h
LEGACY_IMS_ENABLED=true                 # set "false" to disable wholesale
LEGACY_PASSWORD_REHASH=true             # one-time rehash on first plaintext login

# ---- CORS — InstaCafe + legacy IMS ----
# Each CLIENT_URL_* var accepts ONE origin OR a comma-separated list.
# Set these in the Render dashboard for the production backend.
CLIENT_URL_1=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003
CLIENT_URL_DEV=http://localhost:3000
CLIENT_URL_PROD=https://insta-cafe.vercel.app,https://insta-cafe-store.vercel.app,https://insta-cafe-store-admin.vercel.app,https://insta-cafe-master-admin.vercel.app

# ---- Rate limiting (auth routes) ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ---- CSRF ----
# Off by default in dev/test; auto-on in production. Forced off when
# CSRF_DISABLED=true (used by unit tests).
CSRF_ENABLED=false
# CSRF_DISABLED=true

# ---- Admin seed (first boot only) ----
ADMIN_EMAIL=admin@instacafe.com
ADMIN_PASSWORD=ChangeMe@Secure123

# ---- Crypto ----
BCRYPT_ROUNDS=10
LOG_LEVEL=info

# ---- OTP / lockout ----
OTP_EXPIRY_MS=600000
OTP_RESEND_LIMIT=3
OTP_RESEND_WINDOW_MS=3600000
ACCOUNT_LOCKOUT_DURATION_MS=900000

# Delivery OTP — never echoed in the order response.
# email | sms | console (dev only)
DELIVERY_OTP_DELIVERY_CHANNEL=console

# ---- Disposable email blocklist ----
# DISABLE_DISPOSABLE_EMAIL_CHECK=true
# DISPOSABLE_EMAIL_EXTRA=custom-temp.com,another.bad

# ---- Email (OTP) — optional in dev (logged to console in test) ----
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SENDER_EMAIL=
SMTP_FROM_NAME=InstaCafe

# ---- Orders ----
# dev/test: "true" auto-marks payment success (Razorpay bypass for fixtures).
# Production: MUST be "false" — env validator will refuse to boot otherwise.
ORDER_AUTO_PAYMENT_SUCCESS=true

# ---- Razorpay (prod-required) ----
# Use dashboard *test* keys (rzp_test_*) in local .env. Never commit real
# secrets. The webhook secret matches the value configured in Razorpay
# dashboard → Settings → Webhooks.
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ---- Cloudinary (prod-required) ----
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ---- Menu images fallback when Cloudinary unset ----
IMAGE_UPLOAD_DIR=public/menu

# ---- Google OAuth — optional ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4469/api/v1/auth/user/oauth/callback
API_URL=http://localhost:4469

# ---- Debug ----
# When "true", error responses include stack traces. Never on in prod.
DEBUG_ERROR_STACK=false

# ---- VendorBridge quotations (SPEC-VB-003) ----
DEFAULT_CURRENCY=INR
QUOTATION_IDEMPOTENCY_TTL_S=86400
QUOTATION_EXPIRY_TICK_MS=60000

# ---- VendorBridge AI quotations (SPEC-VB-003-AI) ----
# Provider: "heuristic" (default, offline, deterministic) or "llm".
# If "llm" is selected but the LLM_* keys below are unset, the system falls
# back to the heuristic provider automatically (no hard failure, NFR-8).
QUOTATION_AI_PROVIDER=heuristic
QUOTATION_AI_SESSION_TTL_S=86400
AI_PEER_MIN_SAMPLES=3
QUOTATION_AI_RATE_PER_MIN=20
# Optional OpenAI-compatible LLM provider (leave blank to stay on heuristic)
QUOTATION_AI_LLM_BASE_URL=
QUOTATION_AI_LLM_API_KEY=
QUOTATION_AI_LLM_MODEL=
