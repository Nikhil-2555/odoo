# Production interconnection — master admin (master.apdu.com).
# NEXT_PUBLIC_* (incl. Clerk publishable key) are baked at build time.
NEXT_PUBLIC_API_URL=https://api.apdu.com/api/v1
NEXT_PUBLIC_APP_NAME=InstaCafe Master Admin
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxx

# Clerk SECRET key is runtime-only (set in infra/master-admin.env, NOT here).
# CLERK_SECRET_KEY=sk_live_xxx
